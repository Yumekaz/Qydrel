// gc_test.lang - Tests garbage collection
// This program allocates multiple global arrays and demonstrates GC

int a1[10];
int a2[10];
int a3[10];
int a4[10];
int a5[10];
int a6[10];
int a7[10];
int a8[10];
int a9[10];
int a10[10];

func fill_array(int base, int start) {
    int i = 0;
    while (i < 10) {
        if (base == 1) { a1[i] = start + i; }
        if (base == 2) { a2[i] = start + i; }
        if (base == 3) { a3[i] = start + i; }
        i = i + 1;
    }
    return 0;
}

func sum_array(int base) {
    int sum = 0;
    int i = 0;
    while (i < 10) {
        if (base == 1) { sum = sum + a1[i]; }
        if (base == 2) { sum = sum + a2[i]; }
        if (base == 3) { sum = sum + a3[i]; }
        i = i + 1;
    }
    return sum;
}

func main() {
    fill_array(1, 0);
    fill_array(2, 10);
    fill_array(3, 20);
    
    int total = sum_array(1) + sum_array(2) + sum_array(3);
    print total;
    return total;
}
